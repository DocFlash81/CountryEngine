# Decision tree
decision <- NA
if ( !is.na( Inter ) && Inter < alpha ) {
if ( !is.na( Time ) && Time < alpha ) {
decision <- "Not parallel + Time effect"
} else {
decision <- "Not parallel, flat"
} } else {
