library( readxl )
library( lme4 )
library( lmerTest )
setwd( "~/Documents/Kate" )
file_path <- "FS MAIN STUDY Data Spreadsheet 3-6-26 4pm.xlsx"
sheets <- excel_sheets( file_path )
comp <- read_excel( file_path, sheet = sheets[ 1 ] )
eligible_ids <- comp %>%
filter( MainCriteria == "Y" ) %>%
pull( ID ) %>%
unique()
demo <- read_excel( file_path, sheet = sheets[ 2 ] ) %>% filter( ID %in% eligible_ids ) %>%
select( ID, Study, Condition, Location, Program, ProgramDate, Dage, Pedlevel, income ) %>% data.frame()
clean_wave <- function( df, time_value ) {
df %>%
rename_with( ~ str_replace( ., "[1-4]$", "" ) ) %>%
mutate( Time = time_value )
}
ppre <- read_excel( file_path, sheet = sheets[ 3 ] ) %>%
filter( ID %in% eligible_ids ) %>% select( ID:PComments1 ) %>% clean_wave( ., 1 ) %>% data.frame()
pmid <- read_excel( file_path, sheet = sheets[ 4 ] ) %>%
filter( ID %in% eligible_ids ) %>% select( ID:PComments2 ) %>% clean_wave( ., 2 ) %>% data.frame()
ppos <- read_excel( file_path, sheet = sheets[ 5 ] ) %>%
filter( ID %in% eligible_ids ) %>% select( ID:PComments3 ) %>% clean_wave( ., 3 ) %>% data.frame()
pdel <- read_excel( file_path, sheet = sheets[ 6 ] ) %>%
filter( ID %in% eligible_ids ) %>% select( ID:PComments4 ) %>% clean_wave( ., 4 ) %>% data.frame()
dpre <- read_excel( file_path, sheet = sheets[ 7 ] ) %>%
filter( ID %in% eligible_ids ) %>% select( ID:DComments1 ) %>% clean_wave( ., 1 ) %>% data.frame()
dmid <- read_excel( file_path, sheet = sheets[ 8 ] ) %>%
filter( ID %in% eligible_ids ) %>% select( ID:DComments2 ) %>% clean_wave( ., 2 ) %>% data.frame()
dpos <- read_excel( file_path, sheet = sheets[ 9 ] ) %>%
filter( ID %in% eligible_ids ) %>% select( ID:DComments3 ) %>% clean_wave( ., 3 ) %>% data.frame()
ddel <- read_excel( file_path, sheet = sheets[ 10 ] ) %>%
filter( ID %in% eligible_ids ) %>% select( ID:DComments4 ) %>% clean_wave( ., 4 ) %>% data.frame()
fpbl <- read_excel( file_path, sheet = sheets[ 11 ] ) %>% data.frame()
parent <- bind_rows( ppre, pmid, ppos, pdel ) %>% left_join( demo, by = "ID" )
parent[ parent == "." ] <- NA
parent[ parent == "n/a" ] <- NA
parent$income <- as.numeric( parent$income )
parent$Pedlevel <- as.numeric( parent$Pedlevel )
parent$Condition <- as.character( parent$Condition )
parent$Condition[ parent$Condition == "Both" ]    <- "Treatment"
parent$Condition[ parent$Condition == "Control" ] <- "Control"
parent$Condition <- factor( parent$Condition, levels = c( "Control", "Treatment" ) )
# Count Condition by ProgramDate. We must only uses ProgramDates that have both conditions
tab <- with( parent, table( ProgramDate, Condition ) )
balanced_dates <- rownames( tab )[ rowSums( tab > 0 ) == 2 ]
parent_bal <- parent[ parent$ProgramDate %in% balanced_dates, ]
with( parent_bal, table( ProgramDate, Condition ) )
run_model_decision <- function( data, var, alpha = 0.05 ) {
# Build formulas
form_add <- as.formula(
paste( var, "~ Time + Condition + Pedlevel + income + Location + ProgramDate + ( 1 | ID )" ) )
form_full <- as.formula(
paste( var, "~ Time * Condition + Pedlevel + income + Location + ProgramDate + ( 1 | ID )" ) )
# Fit models
mod_add  <- lmer( form_add,  data = data, REML = FALSE )
mod_full <- lmer( form_full, data = data, REML = FALSE )
an_add  <- anova( mod_add,  test = "ChiSq" )
an_full <- anova( mod_full, test = "ChiSq" )
# Extract p-values safely
Add   <- if ( "Time" %in% rownames( an_add ) )      an_add[ "Time", "Pr(>F)" ] else NA
Time  <- if ( "Time" %in% rownames( an_full ) )     an_full[ "Time", "Pr(>F)" ] else NA
Inter <- if ( "Time:Condition" %in% rownames( an_full ) ) an_full[ "Time:Condition", "Pr(>F)" ] else NA
# Decision tree
decision <- NA
if ( !is.na( Inter ) && Inter < alpha ) {
if ( !is.na( Time ) && Time < alpha ) {
decision <- "Not parallel + Time effect"
} else {
decision <- "Not parallel, flat"
} } else {
if ( !is.na( Add ) && Add < alpha ) {
decision <- "Parallel + Time effect"
} else {
decision <- "No effect"
} }
print( var )
data.frame(
Variable = var,
Add      = round( Add, 3 ),
Time     = round( Time, 3 ),
Inter.   = round( Inter, 3 ),
Decision = decision,
stringsAsFactors = FALSE )
}
run_treatment_only <- function(data, var, alpha = 0.05) {
form <- as.formula( paste(var, "~ Time + Pedlevel + income + Location + ProgramDate + (1 | ID)") )
mod <- lmer(form, data = data, REML = FALSE)
an  <- anova(mod, test = "ChiSq")
p_time <- if ("Time" %in% rownames(an)) an["Time", grep("Pr", colnames(an), value = TRUE)] else NA
decision <- if (!is.na(p_time) && p_time < alpha) "Time effect (treatment only)" else "No time effect"
print( var )
data.frame( Variable = var, p_time = round( p_time, 3 ), Decision = decision, stringsAsFactors = FALSE )
}
main_vars     <- parent_bal %>% select( Pconfident, newPboysbetterR:Phelphomework ) %>% names()
trt_only_vars <- parent_bal %>% select( Pprodbenefits:Ppgresources ) %>% names()
parent_bal[ main_vars ] <- lapply( parent_bal[ main_vars ], function( x ) as.numeric( x ) )
parent_bal[ trt_only_vars ] <- lapply( parent_bal[ trt_only_vars ], function( x ) as.numeric( x ) )
parent_bal$income <- as.numeric( parent_bal$income )
main_results <- lapply( main_vars, function( v ) run_model_decision( parent_bal, v ) )
main_results_table <- do.call( rbind, main_results )
row.names( main_results_table ) <- NULL
trt_only_results       <- lapply( trt_only_vars, function( v ) run_treatment_only( parent_bal, v ) )
trt_only_results_table <- do.call( rbind, trt_only_results )
row.names( trt_only_results_table ) <- NULL
print( main_results_table )
print( trt_only_results_table )
plot_variable <- function( data, var, y_min = 1, y_max = 5 ) {
df <- data %>%
select(ID, Time, Condition, all_of(var)) %>%
filter(!is.na(.data[[var]])) %>%
group_by(Time, Condition) %>%
summarise( mean = mean(.data[[var]], na.rm = TRUE),
se = sd(.data[[var]], na.rm = TRUE) / sqrt(n()),
.groups = "drop" ) %>%
data.frame()
ggplot( df, aes( x = Time, y = mean, color = Condition, group = Condition ) ) +
geom_line( size = 1.1 ) +
geom_point( size = 3 ) +
geom_errorbar( aes( ymin = mean - se, ymax = mean + se ), width = 0.08, size = 0.8 ) +
scale_x_continuous( breaks = 1:4, name   = "Survey Wave" ) +
scale_y_continuous( limits = c( y_min, y_max ), name   = "Mean ± SE" ) +
theme_minimal(base_size = 13) +
theme( legend.position = "bottom", legend.title = element_blank(), panel.grid.minor = element_blank() )
}
