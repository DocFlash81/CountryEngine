fdf        <- fpbl %>% filter( !is.na( ID ) ) %>% data.frame()
fdf$pmlu   <- as.numeric( fdf$pmlu )
fdf$Week   <- trimws( fdf$Week )
fdf$Week   <- gsub( "\\r\\n", "", fdf$Week )
fdf$Week   <- as.numeric( gsub("W", "", fdf$Week ) )
fdf$cWeek  <- scale( fdf$Week, center = TRUE, scale = FALSE )
fdf$cWeek2 <- fdf$cWeek ^ 2
run_fpbl_model <- function(data, var) {
if (!var %in% names(data)) return(NULL)
form <- as.formula(
paste0(var, " ~ cWeek + cWeek2 + Program + Location + (1 | ID)")
)
mod <- try(lmer(form, data = data, REML = FALSE), silent = TRUE)
if (inherits(mod, "try-error")) return(NULL)
an  <- anova(mod)
p_week  <- an["cWeek", "Pr(>F)"]
p_week2 <- an["cWeek2", "Pr(>F)"]
p_prog  <- an["Program", "Pr(>F)"]
p_loc   <- an["Location", "Pr(>F)"]
sig <- c()
if (!is.na(p_week)  && p_week  < 0.05) sig <- c(sig, "Week")
if (!is.na(p_week2) && p_week2 < 0.05) sig <- c(sig, "Week")
if (!is.na(p_prog)  && p_prog  < 0.05) sig <- c(sig, "Program")
if (!is.na(p_loc)   && p_loc   < 0.05) sig <- c(sig, "Location")
decision <- if (length(sig) == 0) "None" else paste(unique(sig), collapse = " + ")
data.frame(
Variable   = var,
p_Week     = round(p_week, 3),
p_Week2    = round(p_week2, 3),
p_Program  = round(p_prog, 3),
p_Location = round(p_loc, 3),
Decision   = decision
)
}
parent_vars <- c( "paha", "pcaution", "pep", "pfrust", "phelp", "pi", "pnegse", "pposse" )
child_vars  <- c( "caha", "cep", "cfrust", "cnegse", "cposse", "cseek" )
parent_turn_vars <- c( "paha", "pcaution", "pep", "pfrust", "phelp", "pi", "pnegse", "pposse" )
child_turn_vars  <- c( "caha", "cep", "cfrust", "cnegse", "cposse", "cseek")
other_vars <- setdiff( names(fpbl), c( parent_turn_vars, child_turn_vars, "pturn", "cturn", "duration", "Week", "Program", "Location", "ID", "Study", "ProgramDate" ) )
plot_fpbl <- function(data, var) {
if (!var %in% names(data)) return(NULL)
library(dplyr)
library(ggplot2)
plot_data <- data %>%
filter(!is.na(.data[[var]])) %>%
group_by(Week, Program) %>%
summarise(
Mean = mean(.data[[var]], na.rm = TRUE),
SE   = sd(.data[[var]], na.rm = TRUE) /
sqrt(n()),
.groups = "drop"
)
ggplot(plot_data,
aes(x = Week,
y = Mean,
color = Program,
group = Program)) +
geom_line(linewidth = 1) +
geom_point(size = 2) +
geom_errorbar(aes(ymin = Mean - SE,
ymax = Mean + SE),
width = 0.2) +
labs(
x = "Week",
y = var,
color = "Program"
) +
theme_minimal(base_size = 12)
}
process_variable <- function(data, var, turn_var = NULL) {
results <- list()
plots   <- list()
cat( paste0( "/nVariable: ", var, "\n\n" ) )
# Always create rate
data[[paste0(var, "_rate")]] <- data[[var]] / data$duration
variants <- c(var, paste0(var, "_rate"))
# Add percent-of-turns only if applicable
if (!is.null(turn_var)) {
data[[paste0(var, "_pct")]] <- data[[var]] / data[[turn_var]]
variants <- c(variants, paste0(var, "_pct")) }
for (vv in variants) {
res <- run_fpbl_model(data, vv)
if (!is.null(res)) results[[length(results)+1]] <- res
plots[[vv]] <- plot_fpbl(data, vv) }
list(
results = do.call(rbind, results),
plots   = plots )
}
parent_output <- lapply( parent_turn_vars, function(v)
process_variable( fdf, v, turn_var = "pturn" ) )
child_output <- lapply(child_turn_vars, function(v)
process_variable( fdf, v, turn_var = "cturn" ) )
other_output <- lapply( other_vars, function(v)
process_variable( fdf, v, turn_var = NULL ) )
parent_summary <- do.call(rbind,
lapply(parent_output, function(x) x$results))
child_summary <- do.call(rbind,
lapply(child_output, function(x) x$results))
other_summary <- do.call(rbind,
lapply(other_output, function(x) x$results))
fpbl_summary <- rbind(parent_summary,
child_summary,
other_summary)
for( i in seq_along( parent_turn_vars ) ) {
var <- parent_turn_vars[i]
cat( "##", var, "\n\n" )
print( parent_output[[i]]$results )
for ( nm in names( parent_output[[i]]$plots ) ) {
print( parent_output[[i]]$plots[[nm]] )
}
cat("\n\n")
}
for( i in seq_along( child_turn_vars ) ) {
var <- child_turn_vars[i]
cat( "##", var, "\n\n" )
print( child_output[[i]]$results )
for ( nm in names( child_output[[i]]$plots ) ) {
print( child_output[[i]]$plots[[nm]] )
}
cat("\n\n")
}
for( i in seq_along( other_vars ) ) {
var <- other_vars[i]
cat( "##", var, "\n\n" )
print( other_output[[i]]$results )
for ( nm in names( other_output[[i]]$plots ) ) {
print( other_output[[i]]$plots[[nm]] )
}
cat("\n\n")
}
