lapply(parent_output, function(x) x$results))
child_summary <- do.call(rbind,
lapply(child_output, function(x) x$results))
other_summary <- do.call(rbind,
lapply(other_output, function(x) x$results))
fpbl_summary <- rbind(parent_summary,
child_summary,
other_summary)
for( i in seq_along( parent_turn_vars ) ) {
var <- parent_turn_vars[i]
cat( "##", var, "\n\n" )
print( parent_output[[i]]$results )
for ( nm in names( parent_output[[i]]$plots ) ) {
print( parent_output[[i]]$plots[[nm]] )
}
cat("\n\n")
}
